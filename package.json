{
  "name": "unplugin-turbo-console",
  "version": "2.3.1",
  "description": "Improve the Developer Experience of console",
  "keywords": [
    "rollup",
    "transform",
    "unplugin",
    "vite",
    "webpack"
  ],
  "homepage": "https://utc.yuy1n.io",
  "bugs": {
    "url": "https://github.com/unplugin/unplugin-turbo-console/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unplugin/unplugin-turbo-console.git"
  },
  "files": [
    "client.d.ts",
    "dist"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./farm": {
      "import": {
        "types": "./dist/farm.d.mts",
        "default": "./dist/farm.mjs"
      },
      "require": {
        "types": "./dist/farm.d.cts",
        "default": "./dist/farm.cjs"
      }
    },
    "./astro": {
      "import": {
        "types": "./dist/astro.d.mts",
        "default": "./dist/astro.mjs"
      },
      "require": {
        "types": "./dist/astro.d.cts",
        "default": "./dist/astro.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.mts",
        "default": "./dist/vite.mjs"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      }
    },
    "./webpack": {
      "import": {
        "types": "./dist/webpack.d.mts",
        "default": "./dist/webpack.mjs"
      },
      "require": {
        "types": "./dist/webpack.d.cts",
        "default": "./dist/webpack.cjs"
      }
    },
    "./rspack": {
      "import": {
        "types": "./dist/rspack.d.mts",
        "default": "./dist/rspack.mjs"
      },
      "require": {
        "types": "./dist/rspack.d.cts",
        "default": "./dist/rspack.cjs"
      }
    },
    "./rollup": {
      "import": {
        "types": "./dist/rollup.d.mts",
        "default": "./dist/rollup.mjs"
      },
      "require": {
        "types": "./dist/rollup.d.cts",
        "default": "./dist/rollup.cjs"
      }
    },
    "./esbuild": {
      "import": {
        "types": "./dist/esbuild.d.mts",
        "default": "./dist/esbuild.mjs"
      },
      "require": {
        "types": "./dist/esbuild.d.cts",
        "default": "./dist/esbuild.cjs"
      }
    },
    "./nuxt": {
      "import": {
        "types": "./dist/nuxt.d.mts",
        "default": "./dist/nuxt.mjs"
      },
      "require": {
        "types": "./dist/nuxt.d.cts",
        "default": "./dist/nuxt.cjs"
      }
    },
    "./helper": {
      "import": {
        "types": "./dist/helper.d.mts",
        "default": "./dist/helper.mjs"
      },
      "require": {
        "types": "./dist/helper.d.cts",
        "default": "./dist/helper.cjs"
      }
    },
    "./client": {
      "types": "./client.d.ts"
    }
  },
  "scripts": {
    "build": "vp pack",
    "build:client": "vp run --filter client build",
    "dev": "vp pack --watch",
    "dev:client": "vp run --filter client dev",
    "lint": "vp lint .",
    "play:vite-vue3": "vp run --filter vite-vue3 dev",
    "play:nuxt": "vp run --filter nuxt-app dev",
    "play:vue3-cli": "vp run --filter vue3-cli serve",
    "play:svelte": "vp run --filter svelte-kit dev",
    "play:rspack": "vp run --filter rspack-vue dev",
    "play:astro": "vp run --filter astro dev",
    "play:farm": "vp run --filter farm-vue dev",
    "play:solid": "vp run --filter solid-start dev",
    "docs:dev": "vp run --filter docs dev",
    "docs:preview": "vp run --filter docs preview",
    "docs:build": "vp run --filter docs build",
    "prepublishOnly": "vp run build",
    "release": "bumpp",
    "test": "vp test",
    "prepare": "vp config"
  },
  "dependencies": {
    "alien-signals": "^3.1.2",
    "estree-walker": "^3.0.3",
    "get-port-please": "^3.2.0",
    "h3": "^1.15.11",
    "launch-editor": "^2.13.2",
    "magic-string": "^0.30.21",
    "mrmime": "^2.0.1",
    "oxc-parser": "^0.126.0",
    "pathe": "^2.0.3",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.4.2",
    "@nuxt/schema": "^4.4.2",
    "@oxc-project/types": "^0.126.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@vitest/ui": "^4.1.4",
    "bumpp": "^11.0.1",
    "rollup": "^4.60.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.18",
    "vite-plugin-inspect": "catalog:",
    "vite-plus": "catalog:",
    "vue": "^3.5.32",
    "webpack": "^5.106.2"
  },
  "peerDependencies": {
    "@farmfe/core": ">=1",
    "@nuxt/kit": ">=3",
    "@nuxt/schema": ">=3",
    "astro": ">=3",
    "esbuild": "*",
    "rollup": ">=3",
    "vite": ">=3",
    "vue": ">=3",
    "webpack": ">=5"
  },
  "peerDependenciesMeta": {
    "@farmfe/core": {
      "optional": true
    },
    "@nuxt/kit": {
      "optional": true
    },
    "@nuxt/schema": {
      "optional": true
    },
    "astro": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sveltejs/kit",
      "esbuild",
      "sharp",
      "vue-demi",
      "svelte-preprocess"
    ]
  }
}
